{
  "name": "maxima",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "MAXIMA — клининг и аренда спецтехники: SSR-сайт + админ-панель",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node server/index.js",
    "dev:watch": "node --watch-path=server/index.js --watch-path=src --watch-path=index.html server/index.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --outDir dist/client --ssrManifest",
    "build:server": "vite build --outDir dist/server --ssr src/entry-server.jsx",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "preview": "npm run build && npm run start",
    "seed:data": "node scripts/seed-content-from-default.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sirv": "^3.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "vite": "^6.0.7"
  }
}
