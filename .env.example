# Скопируйте этот файл в .env и проставьте свои значения.

# Пароль администратора для входа в /admin
ADMIN_PASSWORD=maxima2026

# Альтернатива: bcrypt-хеш пароля. Если задан — ADMIN_PASSWORD игнорируется.
# Сгенерировать: node -e "console.log(require('bcryptjs').hashSync('пароль', 10))"
# ADMIN_PASSWORD_HASH=

# Секрет для подписи JWT-токенов. Любая длинная случайная строка.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=замените-меня-длинной-случайной-строкой

# Порт backend-сервера
PORT=3001

# Публичный домен сайта (используется в SEO, sitemap.xml, robots.txt, OG-тегах).
# Меняйте при переезде на другой домен — менять код не нужно.
PUBLIC_BASE_URL=http://localhost:3001
